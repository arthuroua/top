POSTGRES_DB=carimport
POSTGRES_USER=carimport
POSTGRES_PASSWORD=change-this-postgres-password

REDIS_URL=redis://redis:6379/0
INGESTION_QUEUE_KEY=ingestion:jobs

DATABASE_URL=postgresql+psycopg://carimport:change-this-postgres-password@db:5432/carimport

ADMIN_TOKEN=change-this-admin-token-to-a-long-random-value
CORS_ALLOW_ORIGINS=https://example.com,https://api.example.com
CORS_ALLOW_CREDENTIALS=false

COPART_CONNECTOR_MODE=mock
IAAI_CONNECTOR_MODE=mock

COPART_CSV_ENABLED=true
COPART_CSV_AUTH_KEY=replace-with-copart-auth-key
COPART_CSV_URL_TEMPLATE=https://inventory.copart.io/FTPLSTDM/salesdata.cgi?authKey={auth_key}
COPART_CSV_TIMEOUT_SECONDS=180
COPART_CSV_RETRY_COUNT=2
COPART_CSV_RETRY_BACKOFF_MS=2000
COPART_CSV_MAX_ROWS_PER_RUN=0
COPART_CSV_DEDUPE_TTL_HOURS=168
COPART_CSV_DEDUPE_KEY_PREFIX=ingestion:copart:csv:seen
COPART_CSV_SCHEDULE_TIMES=09:17,21:43
COPART_CSV_TIMEZONE=Europe/Kiev
COPART_CSV_RUN_ON_START=true

MEDIA_PROXY_ALLOWED_HOSTS=copart.com,iaai.com,riastatic.com
HIDE_DATA_SOURCE=true
PUBLIC_SOURCE_LABEL=market

NEXT_PUBLIC_API_BASE_URL=https://api.example.com
API_INTERNAL_BASE_URL=http://api:8000
NEXT_PUBLIC_SITE_URL=https://example.com
SEO_API_ENABLED=true
MARKET_API_ENABLED=true

PUBLIC_WEB_DOMAIN=example.com
PUBLIC_API_DOMAIN=api.example.com
BASIC_AUTH_USER=admin
BASIC_AUTH_PASSWORD=change-this-basic-auth-password
