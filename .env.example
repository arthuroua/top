POSTGRES_DB=carimport
POSTGRES_USER=carimport
POSTGRES_PASSWORD=carimport
POSTGRES_PORT=5432

REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0
INGESTION_QUEUE_KEY=ingestion:jobs
ENRICHMENT_QUEUE_KEY=enrichment:jobs
COPART_CONNECTOR_MODE=mock
IAAI_CONNECTOR_MODE=mock
COPART_API_BASE_URL=
COPART_API_ENDPOINT_PATH=/v1/lots
COPART_VIN_QUERY_PARAM=vin
COPART_LOT_QUERY_PARAM=lot_number
COPART_API_AUTH_HEADER=Authorization
COPART_API_TOKEN=
COPART_API_KEY=
COPART_API_TIMEOUT_SECONDS=15
COPART_API_RETRY_COUNT=2
COPART_API_RETRY_BACKOFF_MS=400
COPART_API_RATE_LIMIT_PER_SECOND=2
IAAI_API_BASE_URL=
IAAI_API_ENDPOINT_PATH=/v1/lots
IAAI_VIN_QUERY_PARAM=vin
IAAI_LOT_QUERY_PARAM=lot_number
IAAI_API_AUTH_HEADER=Authorization
IAAI_API_TOKEN=
IAAI_API_KEY=
IAAI_API_TIMEOUT_SECONDS=15
IAAI_API_RETRY_COUNT=2
IAAI_API_RETRY_BACKOFF_MS=400
IAAI_API_RATE_LIMIT_PER_SECOND=2

COPART_CSV_ENABLED=false
COPART_CSV_AUTH_KEY=
COPART_CSV_URL_TEMPLATE=https://inventory.copart.io/FTPLSTDM/salesdata.cgi?authKey={auth_key}
COPART_CSV_TIMEOUT_SECONDS=180
COPART_CSV_RETRY_COUNT=2
COPART_CSV_RETRY_BACKOFF_MS=2000
COPART_CSV_MAX_ROWS_PER_RUN=0
COPART_CSV_DEDUPE_TTL_HOURS=168
COPART_CSV_DEDUPE_KEY_PREFIX=ingestion:copart:csv:seen
COPART_CSV_SCHEDULE_TIMES=09:17,21:43
COPART_CSV_TIMEZONE=Europe/Kiev
COPART_CSV_RUN_ON_START=false

API_PORT=8000
WEB_PORT=3000
HIDE_DATA_SOURCE=true
PUBLIC_SOURCE_LABEL=market
MEDIA_PROXY_ALLOWED_HOSTS=copart.com,iaai.com,riastatic.com
ADMIN_TOKEN=change-me-admin
PUBLIC_API_RATE_LIMIT_PER_MINUTE=120
PUBLIC_MEDIA_RATE_LIMIT_PER_MINUTE=240
ENRICHMENT_MAX_IMAGES_PER_LOT=2
ENRICHMENT_VERIFY_IMAGE_URLS=true
ENRICHMENT_IMAGE_HEAD_TIMEOUT_SECONDS=8
ENRICHMENT_REQUEST_DELAY_MS=250

AUTORIA_ENABLED=false
AUTORIA_API_KEY=
AUTORIA_BASE_URL=https://developers.ria.com
AUTORIA_DEFAULT_SEARCH_PARAMS=category_id=1&with_photo=1&currency=1&abroad=2&custom=1
AUTORIA_COUNTPAGE=50
AUTORIA_MAX_PAGES=1
AUTORIA_MAX_DETAILS_PER_RUN=100
AUTORIA_TIMEOUT_SECONDS=20
AUTORIA_REQUEST_DELAY_MS=250

NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
API_INTERNAL_BASE_URL=http://api:8000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
SEO_API_ENABLED=true
MARKET_API_ENABLED=true
DATABASE_URL=postgresql+psycopg://carimport:carimport@db:5432/carimport
